<!doctype html>
<html lang="en">
<head>
  <script>(() => { try { const s = localStorage.getItem("themeMode"); if (s ? s === "dark" : matchMedia("(prefers-color-scheme: dark)").matches) document.documentElement.classList.add("dark"); } catch(_){} })();</script>
  <meta charset="utf-8"/><meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>Stok Opname - Facultyware</title>
  <link rel="stylesheet" href="/assets/styles.css"/>
</head>
<body>
  <%- include('../sidebar', { activePage: 'stock', user: user }) %>

  <main id="content">
    <header class="bg-background sticky inset-x-0 top-0 isolate flex shrink-0 items-center gap-2 border-b z-10">
      <div class="flex h-14 w-full items-center gap-2 px-4">
        <button type="button" onclick="document.dispatchEvent(new CustomEvent('basecoat:sidebar'))" class="btn-sm-icon-ghost mr-2 size-7 -ml-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M9 3v18"/></svg>
        </button>
        <a href="/inventory/stock" class="text-sm text-muted-foreground hover:underline">Laporan Stok</a>
        <span class="text-muted-foreground">/</span>
        <span class="text-sm font-medium">Stok Opname: <%= item.name %></span>
      </div>
    </header>

    <div class="p-6 max-w-2xl space-y-4">
      <!-- Info stok sekarang -->
      <div class="card">
        <section class="grid grid-cols-3 gap-4 text-sm">
          <div><span class="text-muted-foreground block text-xs">Kode Barang</span><span class="font-mono font-medium"><%= item.code %></span></div>
          <div><span class="text-muted-foreground block text-xs">Nama Barang</span><span class="font-medium"><%= item.name %></span></div>
          <div><span class="text-muted-foreground block text-xs">Stok Sistem Saat Ini</span><span class="text-2xl font-bold"><%= item.stock %> <span class="text-sm font-normal"><%= item.unit %></span></span></div>
        </section>
      </div>

      <% if (errors.length > 0) { %>
        <div class="rounded-md bg-red-50 border border-red-200 px-4 py-3 text-red-800 text-sm">
          <ul class="list-disc list-inside space-y-1"><% errors.forEach(e => { %><li><%= e %></li><% }) %></ul>
        </div>
      <% } %>

      <div class="card">
        <header><h2>Form Stok Opname</h2><p class="text-muted-foreground text-sm">Masukkan jumlah fisik hasil penghitungan stok aktual</p></header>
        <section>
          <form method="POST" action="/inventory/stock/<%= item.id %>/adjustment" class="form grid gap-4" id="adjustForm">
            <div class="grid gap-2">
              <label for="quantity">Jumlah Fisik Stok (hasil hitung) <span class="text-red-500">*</span></label>
              <input type="number" id="quantity" name="quantity" value="<%= old.quantity ?? item.stock %>" class="input" min="0" required/>
              <p class="text-xs text-muted-foreground">Masukkan jumlah stok yang sebenarnya ada secara fisik</p>
            </div>
            <div id="diffInfo" class="rounded-md px-4 py-3 text-sm hidden"></div>
            <div class="grid gap-2">
              <label for="reference">Nomor Referensi / Dokumen</label>
              <input type="text" id="reference" name="reference" value="<%= old.reference || '' %>" class="input" placeholder="Contoh: OPNAME-2024-001 (opsional)" maxlength="255"/>
            </div>
            <div class="grid gap-2">
              <label for="notes">Alasan / Keterangan <span class="text-red-500">*</span></label>
              <textarea id="notes" name="notes" class="input" rows="3" placeholder="Jelaskan alasan perubahan stok..." required><%= old.notes || '' %></textarea>
            </div>
            <footer class="flex gap-3 justify-end pt-2">
              <a href="/inventory/stock/<%= item.id %>/history" class="btn-outline">Batal</a>
              <button type="submit" class="btn">Simpan Opname</button>
            </footer>
          </form>
        </section>
      </div>
    </div>
  </main>
  <div id="toaster" class="toaster"></div>
  <script src="/assets/js/sidebar.js"></script>
  <script>
    const currentStock = <%= item.stock %>;
    const unit = '<%= item.unit %>';
    const qtyInput = document.getElementById('quantity');
    const diffInfo = document.getElementById('diffInfo');

    qtyInput.addEventListener('input', function() {
      const val = parseInt(this.value);
      if (isNaN(val)) { diffInfo.classList.add('hidden'); return; }
      const diff = val - currentStock;
      diffInfo.classList.remove('hidden', 'bg-green-50', 'bg-red-50', 'bg-blue-50', 'text-green-800', 'text-red-800', 'text-blue-800', 'border-green-200', 'border-red-200', 'border-blue-200', 'border');
      if (diff > 0) {
        diffInfo.className = 'rounded-md px-4 py-3 text-sm bg-green-50 border border-green-200 text-green-800';
        diffInfo.textContent = 'Stok akan bertambah +' + diff + ' ' + unit + ' (dari ' + currentStock + ' menjadi ' + val + ')';
      } else if (diff < 0) {
        diffInfo.className = 'rounded-md px-4 py-3 text-sm bg-red-50 border border-red-200 text-red-800';
        diffInfo.textContent = 'Stok akan berkurang ' + diff + ' ' + unit + ' (dari ' + currentStock + ' menjadi ' + val + ')';
      } else {
        diffInfo.className = 'rounded-md px-4 py-3 text-sm bg-blue-50 border border-blue-200 text-blue-800';
        diffInfo.textContent = 'Tidak ada perubahan stok';
      }
    });

    // Trigger awal
    qtyInput.dispatchEvent(new Event('input'));

    // Validasi client
    document.getElementById('adjustForm').addEventListener('submit', function(e) {
      const qty = document.getElementById('quantity').value;
      const notes = document.getElementById('notes').value.trim();
      const errs = [];
      if (qty === '' || isNaN(qty) || Number(qty) < 0) errs.push('Jumlah stok harus angka positif');
      if (!notes) errs.push('Keterangan wajib diisi');
      if (errs.length > 0) { e.preventDefault(); alert(errs.join('\n')); }
    });
  </script>
</body>
</html>
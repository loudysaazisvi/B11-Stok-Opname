<!doctype html>
<html lang="en">
<head>
  <script>(() => { try { const s = localStorage.getItem("themeMode"); if (s ? s === "dark" : matchMedia("(prefers-color-scheme: dark)").matches) document.documentElement.classList.add("dark"); } catch(_){} })();</script>
  <meta charset="utf-8"/><meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>Stok Opname - <%= item.name %> - Facultyware</title>
  <link rel="stylesheet" href="/assets/styles.css"/>
  <style>
    .info-card { background:var(--card); border:1px solid var(--border); border-radius:0.75rem; overflow:hidden; }
    .info-card-header { padding:1rem 1.5rem; border-bottom:1px solid var(--border); background:var(--muted); }
    .info-card-header h2 { font-size:0.9rem; font-weight:700; margin:0 0 0.15rem; }
    .info-card-header p  { font-size:0.75rem; color:var(--muted-foreground); margin:0; }
    .info-card-body { padding:1.25rem 1.5rem; }
    .stat-row { display:grid; grid-template-columns:repeat(3,1fr); gap:1rem; }
    .stat-item { text-align:center; padding:0.75rem; background:var(--muted); border-radius:0.5rem; }
    .stat-item .val { font-size:1.5rem; font-weight:700; line-height:1; }
    .stat-item .lbl { font-size:0.7rem; color:var(--muted-foreground); margin-top:0.2rem; }
    .field-group { display:flex; flex-direction:column; gap:0.4rem; }
    .field-group label { font-size:0.85rem; font-weight:600; }
    .field-hint { font-size:0.72rem; color:var(--muted-foreground); }
    .required-star { color:#ef4444; }
    .diff-box { border-radius:0.5rem; padding:0.75rem 1rem; font-size:0.85rem; font-weight:500; display:none; }
    .diff-box.show { display:block; }
    .diff-increase { background:rgba(34,197,94,.1);  border:1px solid rgba(34,197,94,.3);  color:#16a34a; }
    .diff-decrease { background:rgba(239,68,68,.1);  border:1px solid rgba(239,68,68,.3);  color:#dc2626; }
    .diff-same     { background:rgba(59,130,246,.1); border:1px solid rgba(59,130,246,.3); color:#2563eb; }
    .dark .diff-increase { background:rgba(34,197,94,.15);  color:#4ade80; }
    .dark .diff-decrease { background:rgba(239,68,68,.15);  color:#f87171; }
    .dark .diff-same     { background:rgba(59,130,246,.15); color:#60a5fa; }
    .alert-error { background:rgba(239,68,68,.08); border:1px solid rgba(239,68,68,.25); color:#dc2626; border-radius:0.5rem; padding:0.75rem 1rem; font-size:0.875rem; }
    .dark .alert-error { background:rgba(239,68,68,.12); color:#f87171; }
  </style>
</head>
<body>
  <%- include('../sidebar', { activePage: 'stock', user: user }) %>

  <main id="content">
    <header class="bg-background sticky inset-x-0 top-0 isolate flex shrink-0 items-center gap-2 border-b z-10">
      <div class="flex h-14 w-full items-center gap-2 px-4">
        <button type="button" onclick="document.dispatchEvent(new CustomEvent('basecoat:sidebar'))" class="btn-sm-icon-ghost mr-2 size-7 -ml-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M9 3v18"/></svg>
        </button>
        <div class="flex items-center gap-1.5 text-sm flex-1">
          <a href="/inventory/stock" class="text-muted-foreground hover:text-foreground transition-colors">Laporan Stok</a>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-muted-foreground"><path d="m9 18 6-6-6-6"/></svg>
          <a href="/inventory/stock/<%= item.id %>/history" class="text-muted-foreground hover:text-foreground transition-colors"><%= item.name %></a>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-muted-foreground"><path d="m9 18 6-6-6-6"/></svg>
          <span class="font-semibold">Stok Opname</span>
        </div>
        <a href="/inventory/stock/<%= item.id %>/history" class="btn-sm-outline">← Riwayat</a>
      </div>
    </header>

    <div class="p-6 space-y-5" style="max-width:680px;">

      <!-- Info Barang -->
      <div class="info-card">
        <div class="info-card-header">
          <h2>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:inline; vertical-align:-2px; margin-right:5px"><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/></svg>
            <%= item.name %>
          </h2>
          <p>Kode: <strong style="font-family:monospace"><%= item.code %></strong> &nbsp;·&nbsp; Satuan: <strong><%= item.unit %></strong></p>
        </div>
        <div class="info-card-body">
          <div class="stat-row">
            <div class="stat-item">
              <div class="val" style="color:<%= item.stock < item.minimal_quantity ? '#ef4444' : '#22c55e' %>"><%= item.stock %></div>
              <div class="lbl">Stok Sistem</div>
            </div>
            <div class="stat-item">
              <div class="val" style="color:#64748b"><%= item.minimal_quantity %></div>
              <div class="lbl">Stok Minimal</div>
            </div>
            <div class="stat-item">
              <div class="val" style="font-size:1rem; color:<%= item.stock < item.minimal_quantity ? '#ef4444' : '#22c55e' %>">
                <%= item.stock < item.minimal_quantity ? '⚠ Rendah' : '✓ Normal' %>
              </div>
              <div class="lbl">Status</div>
            </div>
          </div>
        </div>
      </div>

      <% if (errors.length > 0) { %>
        <div class="alert-error">
          <ul style="list-style:disc; padding-left:1.2rem; margin:0">
            <% errors.forEach(e => { %><li><%= e %></li><% }) %>
          </ul>
        </div>
      <% } %>

      <!-- Form Opname -->
      <div class="info-card">
        <div class="info-card-header">
          <h2>Form Stok Opname</h2>
          <p>Masukkan jumlah fisik stok hasil penghitungan aktual di lapangan</p>
        </div>
        <div class="info-card-body">
          <form method="POST" action="/inventory/stock/<%= item.id %>/adjustment" class="space-y-4" id="adjustForm">

            <div class="field-group">
              <label for="quantity">Jumlah Fisik Stok (hasil hitung) <span class="required-star">*</span></label>
              <input type="number" id="quantity" name="quantity" value="<%= old.quantity ?? item.stock %>" class="input" min="0" required
                     style="font-size:1.1rem; font-weight:600;"/>
              <span class="field-hint">Masukkan jumlah stok yang sebenarnya ada secara fisik</span>
            </div>

            <!-- Live diff preview -->
            <div id="diffInfo" class="diff-box"></div>

            <div class="field-group">
              <label for="reference">Nomor Referensi / Dokumen <span style="font-weight:400; font-size:0.75rem; color:var(--muted-foreground)">(opsional)</span></label>
              <input type="text" id="reference" name="reference" value="<%= old.reference || '' %>" class="input"
                     placeholder="cth: OPNAME-2024-001" maxlength="255" style="font-family:monospace"/>
            </div>

            <div class="field-group">
              <label for="notes">Alasan / Keterangan <span class="required-star">*</span></label>
              <textarea id="notes" name="notes" class="input" rows="3"
                        placeholder="Jelaskan alasan perubahan stok secara singkat..." required><%= old.notes || '' %></textarea>
            </div>

            <div class="flex gap-3 pt-1">
              <button type="submit" class="btn-sm" style="padding:0.5rem 1.5rem">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-right:5px"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/></svg>
                Simpan Opname
              </button>
              <a href="/inventory/stock/<%= item.id %>/history" class="btn-sm-outline" style="padding:0.5rem 1.25rem">Batal</a>
            </div>
          </form>
        </div>
      </div>
    </div>
  </main>

  <div id="toaster" class="toaster"></div>
  <script src="/assets/js/sidebar.js"></script>
  <script>
    const currentStock = <%= item.stock %>;
    const unit = '<%= item.unit %>';
    const qtyInput = document.getElementById('quantity');
    const diffInfo = document.getElementById('diffInfo');

    function updateDiff() {
      const val = parseInt(qtyInput.value);
      if (isNaN(val) || qtyInput.value === '') {
        diffInfo.className = 'diff-box';
        return;
      }
      const diff = val - currentStock;
      if (diff > 0) {
        diffInfo.className = 'diff-box show diff-increase';
        diffInfo.innerHTML = `<strong>▲ Stok bertambah +${diff} ${unit}</strong> — dari ${currentStock} → ${val}`;
      } else if (diff < 0) {
        diffInfo.className = 'diff-box show diff-decrease';
        diffInfo.innerHTML = `<strong>▼ Stok berkurang ${diff} ${unit}</strong> — dari ${currentStock} → ${val}`;
      } else {
        diffInfo.className = 'diff-box show diff-same';
        diffInfo.innerHTML = `<strong>= Tidak ada perubahan</strong> — stok tetap ${currentStock} ${unit}`;
      }
    }

    qtyInput.addEventListener('input', updateDiff);
    updateDiff();

    document.getElementById('adjustForm').addEventListener('submit', function(e) {
      const qty = document.getElementById('quantity').value;
      const notes = document.getElementById('notes').value.trim();
      const errs = [];
      if (qty === '' || isNaN(qty) || Number(qty) < 0) errs.push('Jumlah stok harus berupa angka positif');
      if (!notes) errs.push('Keterangan wajib diisi');
      if (errs.length > 0) { e.preventDefault(); alert(errs.join('\n')); }
    });
  </script>
</body>
</html>
<!doctype html>
<html lang="en">
<head>
  <script>(() => { try { const s = localStorage.getItem("themeMode"); if (s ? s === "dark" : matchMedia("(prefers-color-scheme: dark)").matches) document.documentElement.classList.add("dark"); } catch(_){} })();</script>
  <meta charset="utf-8"/><meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>Laporan Stok - Facultyware</title>
  <link rel="stylesheet" href="/assets/styles.css"/>
  <script src="https://unpkg.com/htmx.org@2.0.4"></script>
</head>
<body>
  <%- include('../sidebar', { activePage: 'stock', user: user }) %>

  <main id="content">
    <header class="bg-background sticky inset-x-0 top-0 isolate flex shrink-0 items-center gap-2 border-b z-10">
      <div class="flex h-14 w-full items-center gap-2 px-4">
        <button type="button" onclick="document.dispatchEvent(new CustomEvent('basecoat:sidebar'))" class="btn-sm-icon-ghost mr-2 size-7 -ml-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M9 3v18"/></svg>
        </button>
        <span class="font-semibold text-sm">Laporan Stok Barang</span>
      </div>
    </header>

    <div class="p-6 space-y-4">
      <% if (success) { %><div class="rounded-md bg-green-50 border border-green-200 px-4 py-3 text-green-800 text-sm"><%= success %></div><% } %>
      <% if (error) { %><div class="rounded-md bg-red-50 border border-red-200 px-4 py-3 text-red-800 text-sm"><%= error %></div><% } %>

      <div class="card">
        <section>
          <form method="GET" action="/inventory/stock" class="flex gap-3 flex-wrap items-end">
            <div class="grid gap-1 flex-1 min-w-[200px]">
              <label class="text-sm font-medium">Cari Barang</label>
              <input type="text" name="search" value="<%= search %>" placeholder="Nama atau kode..." class="input"/>
            </div>
            <div class="grid gap-1">
              <label class="text-sm font-medium">Filter</label>
              <select name="filter" class="input">
                <option value="" <%= filter==='' ? 'selected' : '' %>>Semua</option>
                <option value="low" <%= filter==='low' ? 'selected' : '' %>>Stok Rendah</option>
              </select>
            </div>
            <button type="submit" class="btn-sm">Tampilkan</button>
            <% if (search || filter) { %><a href="/inventory/stock" class="btn-sm-outline">Reset</a><% } %>
          </form>
        </section>
      </div>

      <div class="card">
        <section class="p-0">
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead class="border-b">
                <tr class="text-left">
                  <th class="px-4 py-3 font-medium">No</th>
                  <th class="px-4 py-3 font-medium">Kode</th>
                  <th class="px-4 py-3 font-medium">Nama Barang</th>
                  <th class="px-4 py-3 font-medium">Satuan</th>
                  <th class="px-4 py-3 font-medium">Stok Minimal</th>
                  <th class="px-4 py-3 font-medium">Stok Saat Ini</th>
                  <th class="px-4 py-3 font-medium">Status</th>
                  <th class="px-4 py-3 font-medium">Aksi</th>
                </tr>
              </thead>
              <tbody>
                <% if (items.length === 0) { %>
                  <tr><td colspan="8" class="px-4 py-8 text-center text-muted-foreground">Tidak ada data</td></tr>
                <% } else { %>
                  <% items.forEach((item, idx) => { %>
                    <tr class="border-b hover:bg-muted/50">
                      <td class="px-4 py-3"><%= (currentPage-1)*10+idx+1 %></td>
                      <td class="px-4 py-3 font-mono text-xs"><%= item.code %></td>
                      <td class="px-4 py-3 font-medium"><%= item.name %></td>
                      <td class="px-4 py-3"><%= item.unit %></td>
                      <td class="px-4 py-3"><%= item.minimal_quantity %></td>
                      <td class="px-4 py-3">
                        <span class="<%= item.stock < item.minimal_quantity ? 'text-red-600 font-bold' : 'text-green-700 font-semibold' %>">
                          <%= item.stock %>
                        </span>
                      </td>
                      <td class="px-4 py-3">
                        <% if (item.stock < item.minimal_quantity) { %>
                          <span class="bg-red-100 text-red-700 text-xs px-2 py-0.5 rounded">Stok Rendah</span>
                        <% } else { %>
                          <span class="bg-green-100 text-green-700 text-xs px-2 py-0.5 rounded">Normal</span>
                        <% } %>
                      </td>
                      <td class="px-4 py-3">
                        <div class="flex gap-1">
                          <a href="/inventory/stock/<%= item.id %>/history" class="btn-sm-outline">Riwayat</a>
                          <a href="/inventory/stock/<%= item.id %>/adjustment" class="btn-sm">Opname</a>
                        </div>
                      </td>
                    </tr>
                  <% }) %>
                <% } %>
              </tbody>
            </table>
          </div>
        </section>
        <% if (totalPages > 1) { %>
        <footer class="flex items-center justify-between px-4 py-3 border-t">
          <span class="text-sm text-muted-foreground">Total: <%= totalData %> barang</span>
          <div class="flex gap-1">
            <% for (let i = 1; i <= totalPages; i++) { %>
              <a href="/inventory/stock?page=<%= i %>&search=<%= search %>&filter=<%= filter %>"
                 class="btn-sm-<%= i===currentPage?'':'outline' %>"><%= i %></a>
            <% } %>
          </div>
        </footer>
        <% } %>
      </div>
    </div>
  </main>
  <div id="toaster" class="toaster"></div>
  <script src="/assets/js/sidebar.js"></script>
</body>
</html>
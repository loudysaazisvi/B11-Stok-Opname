<style>
  /* Premium Sidebar Style Override */
  .custom-sidebar {
    background: linear-gradient(180deg, #1e293b 0%, #0f172a 100%) !important;
    color: #e2e8f0 !important;
    border-right: 1px solid #334155 !important;
    width: 260px !important;
    display: flex;
    flex-direction: column;
    height: 100vh;
    position: fixed;
    left: 0;
    top: 0;
    z-index: 50;
    box-shadow: 4px 0 10px rgba(0,0,0,0.15);
    transform: translateX(-100%);
    transition: transform 0.25s ease-in-out;
  }
  
  .custom-sidebar.open {
    transform: translateX(0);
  }
  
  .custom-sidebar header {
    padding: 1.5rem 1.25rem;
    border-bottom: 1px solid rgba(51, 65, 85, 0.6);
  }
  
  .custom-sidebar .brand-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: #f8fafc;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
  }
  
  .custom-sidebar .brand-icon {
    background-color: #3b82f6;
    color: #ffffff;
    width: 2.25rem;
    height: 2.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.5rem;
    box-shadow: 0 0 12px rgba(59, 130, 246, 0.4);
  }

  .custom-sidebar section {
    flex: 1;
    overflow-y: auto;
    padding: 1.25rem 0;
  }

  .custom-sidebar section::-webkit-scrollbar {
    width: 4px;
  }
  .custom-sidebar section::-webkit-scrollbar-thumb {
    background-color: #475569;
    border-radius: 2px;
  }

  .custom-sidebar .nav-group-title {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #64748b;
    padding: 0.5rem 1.5rem 0.5rem;
  }

  .custom-sidebar ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .custom-sidebar .nav-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1.5rem;
    color: #94a3b8;
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    transition: all 0.2s ease;
    border-left: 3px solid transparent;
  }

  .custom-sidebar .nav-link:hover {
    background-color: rgba(255, 255, 255, 0.03);
    color: #f1f5f9;
  }

  .custom-sidebar .nav-link.active {
    background-color: rgba(59, 130, 246, 0.12);
    color: #60a5fa;
    border-left-color: #3b82f6;
    font-weight: 600;
  }

  /* Submenu Styling with Tree Line */
  .custom-sidebar .submenu-title {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    cursor: pointer;
    user-select: none;
  }

  .custom-sidebar .submenu-list {
    margin-left: 2.25rem;
    border-left: 1px dashed rgba(71, 85, 105, 0.6);
    padding-left: 0.5rem;
    margin-top: 0.25rem;
    margin-bottom: 0.5rem;
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .custom-sidebar .submenu-list.show {
    max-height: 200px;
  }

  .custom-sidebar .submenu-title svg:last-child {
    transition: transform 0.3s ease;
  }

  .custom-sidebar .submenu-link {
    display: flex;
    align-items: center;
    padding: 0.5rem 1rem;
    font-size: 0.825rem;
    color: #94a3b8;
    text-decoration: none;
    transition: all 0.2s ease;
    position: relative;
  }
  
  .custom-sidebar .submenu-link::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    width: 6px;
    height: 1px;
    background-color: rgba(71, 85, 105, 0.6);
  }

  .custom-sidebar .submenu-link:hover {
    color: #f1f5f9;
  }

  .custom-sidebar .submenu-link.active {
    color: #60a5fa;
    font-weight: 600;
  }

  .custom-sidebar footer {
    padding: 1rem 1.25rem;
    border-top: 1px solid rgba(51, 65, 85, 0.6);
    background-color: rgba(15, 23, 42, 0.4);
  }

  .custom-sidebar .user-info {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    justify-content: space-between;
  }

  .custom-sidebar .user-details {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .custom-sidebar .user-name {
    font-size: 0.85rem;
    font-weight: 600;
    color: #f8fafc;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .custom-sidebar .user-role {
    font-size: 0.7rem;
    color: #64748b;
    font-weight: 500;
  }

  .custom-sidebar .btn-logout {
    font-size: 0.7rem;
    font-weight: 600;
    color: #f87171;
    text-decoration: none;
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
    transition: all 0.2s;
    border: 1px solid rgba(248, 113, 113, 0.15);
  }

  .custom-sidebar .btn-logout:hover {
    background-color: rgba(248, 113, 113, 0.1);
    color: #ef4444;
    border-color: rgba(239, 68, 68, 0.3);
  }

  /* Layout Offset for Desktop */
  @media (min-width: 1024px) {
    .custom-sidebar {
      transform: translateX(0) !important;
    }
    #content {
      margin-left: 260px !important;
    }
    .sidebar {
      display: none !important; /* Hide original basecoat sidebar */
    }
  }

  /* Coordinated Premium Theme Overrides for Content (Dark Mode) */
  .dark {
    --background: #0f172a !important; /* Deep Navy/Slate background */
    --card: #1e293b !important;       /* Lighter Slate card background */
    --card-foreground: #f8fafc !important;
    --popover: #1e293b !important;
    --popover-foreground: #f8fafc !important;
    --primary: #3b82f6 !important;     /* Bright premium blue */
    --primary-foreground: #ffffff !important;
    --secondary: #334155 !important;
    --secondary-foreground: #f8fafc !important;
    --muted: #334155 !important;
    --muted-foreground: #94a3b8 !important;
    --border: rgba(51, 65, 85, 0.6) !important; /* Premium border color */
    --input: rgba(51, 65, 85, 0.8) !important;
  }
  
  /* Additional Premium Styling for Tables and Cards */
  .dark body {
    background-color: #0f172a !important;
  }
  
  .dark .card {
    background-color: #1e293b !important;
    border: 1px solid rgba(51, 65, 85, 0.6) !important;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.15), 0 2px 4px -2px rgba(0, 0, 0, 0.15) !important;
  }
  
  .dark header {
    background-color: #0f172a !important;
    border-color: rgba(51, 65, 85, 0.6) !important;
  }
  
  .dark input, .dark select, .dark textarea {
    background-color: #0f172a !important;
    border-color: rgba(51, 65, 85, 0.8) !important;
    color: #f8fafc !important;
  }
  
  .dark input:focus, .dark select:focus, .dark textarea:focus {
    border-color: #3b82f6 !important;
    box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.2) !important;
  }
  
  .dark table {
    border-collapse: collapse !important;
  }
  
  .dark table thead tr {
    background-color: rgba(15, 23, 42, 0.5) !important;
    border-bottom: 1px solid rgba(51, 65, 85, 0.8) !important;
  }
  
  .dark table tbody tr {
    border-bottom: 1px solid rgba(51, 65, 85, 0.4) !important;
    transition: background-color 0.15s ease-in-out;
  }
  
  .dark table tbody tr:hover {
    background-color: rgba(255, 255, 255, 0.02) !important;
  }
  
  /* Make pagination and standard buttons look matching */
  .dark .btn-sm-outline {
    border-color: rgba(51, 65, 85, 0.8) !important;
    color: #94a3b8 !important;
    background-color: transparent !important;
  }
  
  .dark .btn-sm-outline:hover {
    background-color: rgba(255, 255, 255, 0.03) !important;
    color: #f8fafc !important;
    border-color: #94a3b8 !important;
  }
</style>

<aside class="custom-sidebar">
  <header>
    <a href="/inventory/items" class="brand-title">
      <!-- FTI UNAND Logo SVG -->
      <div class="brand-icon" style="background:transparent; box-shadow:none; padding:0; width:36px; height:36px;">
        <img src="/assets/images/logo_fti.png" alt="FTI UNAND Logo" style="width: 100%; height: 100%; object-fit: contain;" />
      </div>
      <div class="brand-text">
        <span style="display: block; font-size: 0.85rem; font-weight: 700; letter-spacing: 0.01em; color: #f8fafc;">Facultyware</span>
        <span style="display: block; font-size: 0.6rem; color: #64748b; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase;">FTI · UNAND</span>
      </div>
    </a>
  </header>

  <section>
    <div class="nav-group-title">Inventori</div>
    <ul>
      <li>
        <a href="/inventory/items" class="nav-link <%= activePage === 'items' ? 'active' : '' %>">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/>
            <path d="m3.3 7 8.7 5 8.7-5"/>
            <path d="M12 22V12"/>
          </svg>
          <span>Data Barang</span>
        </a>
      </li>
      <li>
        <div class="nav-link">
          <div class="submenu-title">
            <div style="display: flex; align-items: center; gap: 0.75rem;">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <rect width="18" height="18" x="3" y="3" rx="2"/>
                <path d="M3 9h18"/>
                <path d="M3 15h18"/>
                <path d="M9 3v18"/>
              </svg>
              <span>Laporan & Stok</span>
            </div>
            <!-- Arrow indicator showing there are branches -->
            <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" style="color: #475569;">
              <path d="m6 9 6 6 6-6"/>
            </svg>
          </div>
        </div>
        
        <ul class="submenu-list">
          <li>
            <a href="/inventory/stock" class="submenu-link <%= activePage === 'stock' ? 'active' : '' %>">
              Laporan Stok
            </a>
          </li>
          <li>
            <a href="/inventory/stock/report" class="submenu-link <%= activePage === 'opname' ? 'active' : '' %>">
              Laporan Opname
            </a>
          </li>
          <li>
            <a href="/inventory/stock/report/history" class="submenu-link <%= activePage === 'history' ? 'active' : '' %>">
              Riwayat Laporan
            </a>
          </li>
        </ul>
      </li>
    </ul>
  </section>

  <footer>
    <div class="user-info">
      <div class="user-details">
        <span class="user-name"><%= typeof user !== 'undefined' ? user : 'Admin' %></span>
        <span class="user-role">Logistik Officer</span>
      </div>
      <a href="/logout" class="btn-logout">Keluar</a>
    </div>
  </footer>
</aside>

<script>
  // Handle mobile sidebar toggle event
  document.addEventListener('DOMContentLoaded', () => {
    document.addEventListener('basecoat:sidebar', () => {
      const sidebar = document.querySelector('.custom-sidebar');
      if (sidebar) {
        sidebar.classList.toggle('open');
      }
    });

    // Handle submenu toggle
    const submenuTitle = document.querySelector('.submenu-title');
    const submenuList = document.querySelector('.submenu-list');
    const arrowIcon = submenuTitle.querySelector('svg:last-child');

    // Set active state icon rotation on load if parent is active
    const isSubmenuActive = <%= ['stock', 'opname', 'history'].includes(activePage) ? 'true' : 'false' %>;
    if (isSubmenuActive) {
      submenuList.classList.add('show');
      submenuList.style.maxHeight = submenuList.scrollHeight + 'px';
      arrowIcon.style.transform = 'rotate(180deg)';
    }

    submenuTitle.addEventListener('click', () => {
      const isShown = submenuList.classList.toggle('show');
      if (isShown) {
        submenuList.style.maxHeight = submenuList.scrollHeight + 'px';
        arrowIcon.style.transform = 'rotate(180deg)';
      } else {
        submenuList.style.maxHeight = '0';
        arrowIcon.style.transform = 'rotate(0deg)';
      }
    });
  });
</script>

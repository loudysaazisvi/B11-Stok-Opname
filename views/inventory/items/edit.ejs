<!doctype html>
<html lang="id">
<head>
  <script>(() => { try { const s = localStorage.getItem("themeMode"); if (s ? s === "dark" : matchMedia("(prefers-color-scheme: dark)").matches) document.documentElement.classList.add("dark"); } catch(_){} })();</script>
  <meta charset="utf-8"/><meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>Edit Barang - <%= item.name %> - Facultyware</title>
  <meta name="description" content="Form edit data barang inventaris logistik"/>
  <link rel="stylesheet" href="/assets/styles.css"/>
  <script src="https://unpkg.com/htmx.org@2.0.4"></script>
  <style>
    .form-card { background: var(--card); border: 1px solid var(--border); border-radius: 0.75rem; overflow: hidden; }
    .form-card-header { padding: 1.25rem 1.5rem; border-bottom: 1px solid var(--border); background: var(--muted); display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; }
    .form-card-header h2 { font-size: 0.95rem; font-weight: 700; margin: 0 0 0.2rem; }
    .form-card-header p { font-size: 0.78rem; color: var(--muted-foreground); margin: 0; }
    .form-card-body { padding: 1.5rem; }
    .field-group { display: flex; flex-direction: column; gap: 0.4rem; }
    .field-group label { font-size: 0.85rem; font-weight: 600; }
    .field-hint { font-size: 0.72rem; color: var(--muted-foreground); margin-top: 0.15rem; }
    .alert-error { background: rgba(239,68,68,0.08); border: 1px solid rgba(239,68,68,0.25); color: #dc2626; border-radius: 0.5rem; padding: 0.875rem 1rem; font-size: 0.875rem; }
    .dark .alert-error { background: rgba(239,68,68,0.12); color: #f87171; }
    .required-star { color: #ef4444; margin-left: 2px; }
    .form-actions { display: flex; gap: 0.75rem; padding-top: 0.75rem; }
    .item-id-badge { display: inline-flex; align-items: center; gap: 0.35rem; background: rgba(59,130,246,0.1); color: #3b82f6; padding: 0.25rem 0.6rem; border-radius: 9999px; font-size: 0.72rem; font-weight: 600; font-family: monospace; }
    .dark .item-id-badge { background: rgba(59,130,246,0.2); color: #60a5fa; }
  </style>
</head>
<body>
  <%- include('../sidebar', { activePage: 'items', user: user }) %>

  <main id="content">
    <header class="bg-background sticky inset-x-0 top-0 isolate flex shrink-0 items-center gap-2 border-b z-10">
      <div class="flex h-14 w-full items-center gap-2 px-4">
        <button type="button" onclick="document.dispatchEvent(new CustomEvent('basecoat:sidebar'))" class="btn-sm-icon-ghost mr-2 size-7 -ml-1.5" aria-label="Toggle sidebar">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M9 3v18"/></svg>
        </button>
        <div class="flex items-center gap-1.5 text-sm flex-1">
          <a href="/inventory/items" class="text-muted-foreground hover:text-foreground transition-colors">Data Barang</a>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-muted-foreground"><path d="m9 18 6-6-6-6"/></svg>
          <span class="font-semibold">Edit: <%= item.name %></span>
        </div>
        <a href="/inventory/items" class="btn-sm-outline" id="btn-kembali-edit">← Kembali</a>
      </div>
    </header>

    <div class="p-6" style="max-width: 680px;">
      <% if (errors && errors.length > 0) { %>
        <div class="alert-error mb-5">
          <p style="font-weight:600; margin:0 0 0.4rem">Mohon perbaiki kesalahan berikut:</p>
          <ul style="list-style:disc; padding-left:1.2rem; margin:0">
            <% errors.forEach(e => { %><li><%= e %></li><% }) %>
          </ul>
        </div>
      <% } %>

      <div class="form-card">
        <div class="form-card-header">
          <div>
            <h2>
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:inline; vertical-align:-2px; margin-right:6px"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/></svg>
              Edit Data Barang
            </h2>
            <p>Perbarui informasi barang yang sudah terdaftar di sistem</p>
          </div>
          <span class="item-id-badge">#<%= item.id %></span>
        </div>
        <div class="form-card-body">
          <form method="POST" action="/inventory/items/<%= item.id %>/edit" class="space-y-5" id="form-edit-barang">

            <div class="field-group">
              <label for="edit-nama">Nama Barang <span class="required-star">*</span></label>
              <input type="text" id="edit-nama" name="name" value="<%= item.name %>"
                     placeholder="cth: Tinta Printer Canon" class="input" required/>
            </div>

            <div class="field-group">
              <label for="edit-kode">Kode Barang <span class="required-star">*</span></label>
              <input type="text" id="edit-kode" name="code" value="<%= item.code %>"
                     placeholder="cth: ITK-001" class="input" required style="font-family:monospace; font-size:0.9rem"/>
              <span class="field-hint">Kode harus unik dan tidak boleh sama dengan barang lain</span>
            </div>

            <div class="grid grid-cols-2 gap-4">
              <div class="field-group">
                <label for="edit-satuan">Satuan <span class="required-star">*</span></label>
                <input type="text" id="edit-satuan" name="unit" value="<%= item.unit %>"
                       placeholder="cth: pcs, rim, lusin" class="input" required/>
              </div>
              <div class="field-group">
                <label for="edit-minimal">Stok Minimal <span class="required-star">*</span></label>
                <input type="number" id="edit-minimal" name="minimal_quantity"
                       value="<%= item.minimal_quantity === -1 ? 0 : item.minimal_quantity %>"
                       placeholder="cth: 5" min="0" class="input" required/>
                <span class="field-hint">Peringatan muncul jika stok di bawah nilai ini</span>
              </div>
            </div>

            <div class="field-group">
              <label for="edit-deskripsi">Deskripsi <span style="font-size:0.75rem; color:var(--muted-foreground); font-weight:400">(opsional)</span></label>
              <textarea id="edit-deskripsi" name="description" rows="3"
                        placeholder="Keterangan tambahan tentang barang ini..." class="input"><%= item.description || '' %></textarea>
            </div>

            <div class="form-actions">
              <button type="submit" class="btn-sm" id="btn-update-barang" style="padding:0.5rem 1.5rem">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-right:5px"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                Perbarui Barang
              </button>
              <a href="/inventory/items" class="btn-sm-outline" id="btn-batal-edit" style="padding:0.5rem 1.25rem">Batal</a>
            </div>
          </form>
        </div>
      </div>
    </div>
  </main>

  <script src="/assets/js/sidebar.js"></script>
</body>
</html>

<!doctype html>
<html lang="id">
<head>
  <script>(() => { try { const s = localStorage.getItem("themeMode"); if (s ? s === "dark" : matchMedia("(prefers-color-scheme: dark)").matches) document.documentElement.classList.add("dark"); } catch(_){} })();</script>
  <meta charset="utf-8"/><meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>Master Data Barang - Facultyware</title>
  <meta name="description" content="Kelola master data barang inventaris logistik fakultas"/>
  <link rel="stylesheet" href="/assets/styles.css"/>
  <script src="https://unpkg.com/htmx.org@2.0.4"></script>
</head>
<body>
  <%- include('../sidebar', { activePage: 'items', user: user }) %>

  <main id="content">
    <header class="bg-background sticky inset-x-0 top-0 isolate flex shrink-0 items-center gap-2 border-b z-10">
      <div class="flex h-14 w-full items-center gap-2 px-4">
        <button type="button" onclick="document.dispatchEvent(new CustomEvent('basecoat:sidebar'))" class="btn-sm-icon-ghost mr-2 size-7 -ml-1.5" aria-label="Toggle sidebar">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M9 3v18"/></svg>
        </button>
        <span class="font-semibold text-sm flex-1">Master Data Barang</span>
        <a href="/inventory/items/create" class="btn-sm" id="btn-tambah-barang">+ Tambah Barang</a>
      </div>
    </header>

    <div class="p-6 space-y-4">
      <% if (success) { %><div class="rounded-md bg-green-50 dark:bg-green-950 border border-green-200 dark:border-green-800 px-4 py-3 text-green-800 dark:text-green-300 text-sm"><%= success %></div><% } %>
      <% if (error) { %><div class="rounded-md bg-red-50 dark:bg-red-950 border border-red-200 dark:border-red-800 px-4 py-3 text-red-800 dark:text-red-300 text-sm"><%= error %></div><% } %>

      <%# Filter & Pencarian %>
      <div class="card">
        <section>
          <form method="GET" action="/inventory/items" class="flex gap-3 flex-wrap items-end" id="form-filter-barang">
            <div class="grid gap-1 flex-1 min-w-[200px]">
              <label class="text-sm font-medium" for="search-barang">Cari Barang</label>
              <input type="text" id="search-barang" name="search" value="<%= search %>" placeholder="Nama atau kode barang..." class="input"/>
            </div>
            <div class="grid gap-1">
              <label class="text-sm font-medium" for="status-barang">Status</label>
              <select id="status-barang" name="status" class="input">
                <option value="" <%= !showInactive ? 'selected' : '' %>>Barang Aktif</option>
                <option value="nonaktif" <%= showInactive ? 'selected' : '' %>>Barang Nonaktif</option>
              </select>
            </div>
            <button type="submit" class="btn-sm" id="btn-cari-barang">Tampilkan</button>
            <% if (search || showInactive) { %><a href="/inventory/items" class="btn-sm-outline" id="btn-reset-filter">Reset</a><% } %>
          </form>
        </section>
      </div>

      <%# Toolbar Ekspor & Impor %>
      <div class="flex gap-2 flex-wrap items-center justify-between">
        <span class="text-sm text-muted-foreground">Total: <strong><%= totalData %></strong> barang <%= showInactive ? '(nonaktif)' : '(aktif)' %></span>
        <div class="flex gap-2">
          <a href="/inventory/items/export" class="btn-sm-outline" id="btn-ekspor-barang">⬇ Ekspor Excel</a>
          <label class="btn-sm-outline cursor-pointer" id="label-impor-barang">
            ⬆ Impor Excel
            <form method="POST" action="/inventory/items/import" enctype="multipart/form-data" id="form-impor-barang">
              <input type="file" name="file" accept=".xlsx,.xls" class="hidden" onchange="this.form.submit()"/>
            </form>
          </label>
        </div>
      </div>

      <%# Tabel Data Barang %>
      <div class="card">
        <section class="p-0">
          <div class="overflow-x-auto">
            <table class="w-full text-sm" id="tabel-barang">
              <thead class="border-b bg-muted/40">
                <tr class="text-left">
                  <th class="px-4 py-3 font-medium">No</th>
                  <th class="px-4 py-3 font-medium">Kode</th>
                  <th class="px-4 py-3 font-medium">Nama Barang</th>
                  <th class="px-4 py-3 font-medium">Satuan</th>
                  <th class="px-4 py-3 font-medium">Stok Minimal</th>
                  <th class="px-4 py-3 font-medium">Stok Saat Ini</th>
                  <th class="px-4 py-3 font-medium">Status Stok</th>
                  <th class="px-4 py-3 font-medium">Aksi</th>
                </tr>
              </thead>
              <tbody>
                <% if (items.length === 0) { %>
                  <tr><td colspan="8" class="px-4 py-10 text-center text-muted-foreground">Tidak ada data barang</td></tr>
                <% } else { %>
                  <% items.forEach((item, idx) => { %>
                    <tr class="border-b hover:bg-muted/30 transition-colors">
                      <td class="px-4 py-3 text-muted-foreground"><%= (currentPage-1)*10+idx+1 %></td>
                      <td class="px-4 py-3 font-mono text-xs bg-muted/30 rounded"><%= item.code %></td>
                      <td class="px-4 py-3 font-medium"><%= item.name %></td>
                      <td class="px-4 py-3"><%= item.unit %></td>
                      <td class="px-4 py-3"><%= item.minimal_quantity %></td>
                      <td class="px-4 py-3">
                        <span class="<%= item.stock < item.minimal_quantity ? 'text-red-600 dark:text-red-400 font-bold' : 'text-green-700 dark:text-green-400 font-semibold' %>">
                          <%= item.stock %>
                        </span>
                      </td>
                      <td class="px-4 py-3">
                        <% if (item.stock < item.minimal_quantity && item.minimal_quantity > 0) { %>
                          <span class="bg-red-100 dark:bg-red-900 text-red-700 dark:text-red-300 text-xs px-2 py-0.5 rounded-full">Stok Rendah</span>
                        <% } else { %>
                          <span class="bg-green-100 dark:bg-green-900 text-green-700 dark:text-green-300 text-xs px-2 py-0.5 rounded-full">Normal</span>
                        <% } %>
                      </td>
                      <td class="px-4 py-3">
                        <div class="flex gap-1 flex-wrap">
                          <a href="/inventory/items/<%= item.id %>/edit" class="btn-sm-outline" id="btn-edit-<%= item.id %>">Edit</a>
                          <a href="/inventory/items/<%= item.id %>/qrcode" class="btn-sm-outline" id="btn-qr-<%= item.id %>">QR</a>
                          <% if (!showInactive) { %>
                            <form method="POST" action="/inventory/items/<%= item.id %>/deactivate" style="display:inline" id="form-nonaktif-<%= item.id %>">
                              <button type="submit" class="btn-sm-outline text-orange-600" onclick="return confirm('Nonaktifkan barang ini?')" id="btn-nonaktif-<%= item.id %>">Nonaktifkan</button>
                            </form>
                          <% } else { %>
                            <form method="POST" action="/inventory/items/<%= item.id %>/activate" style="display:inline" id="form-aktifkan-<%= item.id %>">
                              <button type="submit" class="btn-sm" id="btn-aktifkan-<%= item.id %>">Aktifkan</button>
                            </form>
                          <% } %>
                        </div>
                      </td>
                    </tr>
                  <% }) %>
                <% } %>
              </tbody>
            </table>
          </div>
        </section>

        <% if (totalPages > 1) { %>
        <footer class="flex items-center justify-between px-4 py-3 border-t">
          <span class="text-sm text-muted-foreground">Halaman <%= currentPage %> dari <%= totalPages %></span>
          <div class="flex gap-1">
            <% for (let i = 1; i <= totalPages; i++) { %>
              <a href="/inventory/items?page=<%= i %>&search=<%= search %>&status=<%= showInactive ? 'nonaktif' : '' %>"
                 class="btn-sm<%= i===currentPage ? '' : '-outline' %>" id="btn-page-<%= i %>"><%= i %></a>
            <% } %>
          </div>
        </footer>
        <% } %>
      </div>
    </div>
  </main>

  <script src="/assets/js/sidebar.js"></script>
</body>
</html>

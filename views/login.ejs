<!doctype html>
<html lang="en">
  <head>
    <script>
      (() => {
        try {
          const stored = localStorage.getItem("themeMode");
          if (
            stored
              ? stored === "dark"
              : matchMedia("(prefers-color-scheme: dark)").matches
          ) {
            document.documentElement.classList.add("dark");
          }
        } catch (_) {}

        const apply = (dark) => {
          document.documentElement.classList.toggle("dark", dark);
          try {
            localStorage.setItem("themeMode", dark ? "dark" : "light");
          } catch (_) {}
        };

        document.addEventListener("basecoat:theme", (event) => {
          const mode = event.detail?.mode;
          apply(
            mode === "dark"
              ? true
              : mode === "light"
                ? false
                : !document.documentElement.classList.contains("dark"),
          );
        });
      })();
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Login - Facultyware</title>
    <link rel="stylesheet" href="/assets/styles.css" />
    <style>
      /* Custom Premium Styles for Login */
      body {
        background: radial-gradient(circle at top right, rgba(59, 130, 246, 0.08), transparent 40%),
                    radial-gradient(circle at bottom left, rgba(59, 130, 246, 0.05), transparent 40%),
                    var(--background);
        transition: background-color 0.3s ease;
      }
      .login-card {
        border: 1px solid var(--border) !important;
        background: rgba(var(--card), 0.8) !important;
        backdrop-filter: blur(12px);
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04) !important;
        border-radius: 1rem !important;
        overflow: hidden;
      }
      .brand-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: rgba(59, 130, 246, 0.1);
        color: #3b82f6;
        padding: 0.35rem 0.75rem;
        border-radius: 9999px;
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        margin-bottom: 1rem;
      }
      .input-field {
        transition: all 0.2s ease-in-out;
      }
      .input-field:focus {
        border-color: #3b82f6 !important;
        box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.15) !important;
      }
      .btn-submit {
        background-color: #3b82f6 !important;
        color: #ffffff !important;
        font-weight: 600 !important;
        transition: all 0.2s ease-in-out !important;
        box-shadow: 0 4px 6px -1px rgba(59, 130, 246, 0.2), 0 2px 4px -1px rgba(59, 130, 246, 0.1) !important;
      }
      .btn-submit:hover {
        background-color: #2563eb !important;
        transform: translateY(-1px);
        box-shadow: 0 10px 15px -3px rgba(59, 130, 246, 0.3), 0 4px 6px -2px rgba(59, 130, 246, 0.15) !important;
      }
      .btn-submit:active {
        transform: translateY(0);
      }
      .dark .login-card {
        background: rgba(30, 41, 59, 0.7) !important;
      }
      .dark .brand-badge {
        background: rgba(59, 130, 246, 0.2);
        color: #60a5fa;
      }
    </style>
  </head>
  <body class="bg-background min-h-svh flex flex-col justify-between">
    <!-- Header/Logo area -->
    <div class="w-full max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
      <div class="flex items-center gap-2 font-bold text-lg text-foreground">
        <div class="bg-blue-600 text-white p-1.5 rounded-lg shadow-md">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="size-5">
            <path d="m7.5 4.27 9 5.15"/>
            <path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/>
            <path d="m3.3 7 8.7 5 8.7-5"/>
            <path d="M12 22V12"/>
          </svg>
        </div>
        <span>Facultyware</span>
      </div>
      <!-- Theme toggle or backup info -->
      <span class="text-xs text-muted-foreground font-medium">Logistik & Inventori System</span>
    </div>

    <!-- Login Card Container -->
    <div class="flex-1 flex items-center justify-center p-6 md:p-10">
      <div class="w-full max-w-sm md:max-w-4xl">
        <div class="login-card rounded-2xl border bg-card text-card-foreground shadow-xl overflow-hidden p-0">
          <div class="grid p-0 md:grid-cols-2">
            
            <!-- Left Column: Form -->
            <form class="p-8 md:p-10 flex flex-col justify-center" action="/login" method="POST">
              <div class="flex flex-col gap-6">
                <div class="flex flex-col items-center md:items-start gap-1">
                  <div class="brand-badge">Logistik Portal</div>
                  <h1 class="text-2xl font-bold tracking-tight text-foreground">Selamat Datang</h1>
                  <p class="text-sm text-muted-foreground text-center md:text-left">
                    Masukkan akun Anda untuk mengelola inventori.
                  </p>
                </div>
                
                <% if (error) { %>
                  <div class="bg-destructive/10 text-destructive text-sm p-3.5 rounded-lg border border-destructive/20 text-center font-medium animate-pulse">
                    <%= error %>
                  </div>
                <% } %>

                <div class="flex flex-col gap-4">
                  <!-- Username Field -->
                  <div class="flex flex-col gap-2">
                    <label class="text-sm font-semibold text-foreground" for="username">Username / Email</label>
                    <input
                      type="text"
                      name="username"
                      class="input-field h-10 w-full rounded-lg border border-input bg-background/50 px-3.5 py-2 text-sm outline-none placeholder:text-muted-foreground disabled:opacity-50 dark:bg-slate-900/30"
                      id="username"
                      placeholder="admin atau admin@facultyware.com"
                      required
                    />
                  </div>

                  <!-- Password Field -->
                  <div class="flex flex-col gap-2">
                    <div class="flex items-center justify-between">
                      <label class="text-sm font-semibold text-foreground" for="password">Password</label>
                      <a href="#" class="text-xs text-blue-600 hover:underline">Lupa password?</a>
                    </div>
                    <input
                      type="password"
                      name="password"
                      class="input-field h-10 w-full rounded-lg border border-input bg-background/50 px-3.5 py-2 text-sm outline-none placeholder:text-muted-foreground disabled:opacity-50 dark:bg-slate-900/30"
                      id="password"
                      placeholder="••••••••"
                      required
                    />
                  </div>
                </div>

                <button
                  type="submit"
                  class="btn-submit inline-flex h-10 items-center justify-center rounded-lg text-sm font-semibold shadow-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2"
                >
                  Masuk Ke Dashboard
                </button>

                <p class="text-xs text-muted-foreground text-center">
                  Butuh bantuan akses? Hubungi <a href="#" class="text-blue-600 hover:underline">System Administrator</a>
                </p>
              </div>
            </form>
            
            <!-- Right Column: Artwork Image -->
            <div class="relative hidden bg-slate-950 md:block">
              <img
                src="/assets/images/login_artwork.png"
                alt="Branding Artwork"
                class="absolute inset-0 h-full w-full object-cover opacity-85 dark:opacity-75"
              />
              <!-- Subtle overlay gradients -->
              <div class="absolute inset-0 bg-gradient-to-r from-card via-transparent to-transparent pointer-events-none"></div>
              <div class="absolute inset-0 bg-gradient-to-t from-slate-950/40 via-transparent to-transparent pointer-events-none"></div>
              
              <!-- Subtle watermark brand in bottom right corner -->
              <div class="absolute bottom-6 right-6 text-white/50 text-xs font-mono tracking-wider uppercase">
                Facultyware System
              </div>
            </div>
            
          </div>
        </div>
      </div>
    </div>

    <!-- Footer area -->
    <div class="w-full max-w-7xl mx-auto px-6 py-4 flex flex-col md:flex-row items-center justify-between gap-2 border-t border-border/40 text-xs text-muted-foreground">
      <p>&copy; 2026 Facultyware. All rights reserved.</p>
      <div class="flex gap-4">
        <a href="#" class="hover:text-foreground">Terms of Service</a>
        <a href="#" class="hover:text-foreground">Privacy Policy</a>
      </div>
    </div>
    <div id="toaster" class="toaster"></div>
  </body>
</html>
